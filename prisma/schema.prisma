// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  // native = macOS/Windows dev
  // linux-musl-openssl-3.0.x = Docker (node:20-alpine)
  // rhel-openssl-3.0.x = Vercel serverless (Amazon Linux)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon uses connection pooling — direct URL is used for migrations only
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // null for OAuth-only users
  role          String    @default("CUSTOMER") // "PROFESSIONAL" | "CUSTOMER"
  bio           String?
  speciality    String? // e.g. "Dentist", "Coach"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  slots    Slot[]    @relation("ProfessionalSlots")
  bookings Booking[] @relation("CustomerBookings")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Slot {
  id             String   @id @default(cuid())
  professionalId String
  startTime      DateTime
  endTime        DateTime
  isBooked       Boolean  @default(false) // denormalized flag for fast filtering
  createdAt      DateTime @default(now())

  professional User     @relation("ProfessionalSlots", fields: [professionalId], references: [id], onDelete: Cascade)
  booking      Booking?
}

model Booking {
  id         String   @id @default(cuid())
  slotId     String   @unique // 1:1 with Slot
  customerId String
  status     String   @default("CONFIRMED") // "CONFIRMED" | "CANCELLED"
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  slot     Slot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  customer User @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
}
